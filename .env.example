# ---------------------------------------------------------------------------
# Otonom Bakım ve Parça Yönetim Sistemi — ortam değişkenleri
# Bu dosyayı `.env` olarak kopyalayıp değerleri doldurun.
#   cp .env.example .env
# Kimlik bilgileri (AWS_ACCESS_KEY_ID vb.) BU DOSYAYA YAZILMAZ.
# AWS kimliği `aws configure` veya ortam değişkenleri/SSO ile sağlanır.
# ---------------------------------------------------------------------------

# AWS bölgesi — Frankfurt
AWS_REGION=eu-central-1

# Bedrock model ID.
# Başlangıç modeli Amazon Nova (multimodal + tool-use).
# EU'da büyük olasılıkla cross-region inference profili gerekir.
# TODO: Bedrock Playground'dan bölgede erişilebilir tam ID'yi doğrulayın.
BEDROCK_MODEL_ID=eu.amazon.nova-lite-v1:0

# Bedrock Knowledge Base (RAG) — sync edilince USE_REAL_KB=true yapın.
KNOWLEDGE_BASE_ID=LYKPLY3GMD
DATA_SOURCE_ID=E0GIBVCAQM

# RAG gerçek mi yoksa stub mı? Kota/sync hazır olana kadar false.
USE_REAL_KB=false

# Bedrock'a hiç bağlanmadan deterministik offline akışla çalış (demo/CI için).
# true => AWS kimliği aranmaz, ajan mock reasoning ile uçtan uca çalışır.
# false => boto3 converse tool-use döngüsü kullanılır (AWS kimliği gerekir).
OFFLINE_MODE=true

# Sipariş onay eşiği (TL). Bu tutarın üstündeki taslaklar açıkça
# "yönetici onayı gerekli" olarak işaretlenir. Her taslak zaten insan onayına tabidir.
ORDER_APPROVAL_THRESHOLD=5000

# SQLite veritabanı yolu (datasource katmanı bunu kullanır).
DB_PATH=data/obpys.db
